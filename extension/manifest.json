{
  "manifest_version": 3,
  "name": "Khazana PDF Downloader",
  "version": "1.5.4",
  "permissions": [
    "webRequest",
    "storage",
    "downloads",
    "scripting",
    "tabs",
    "webNavigation",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}