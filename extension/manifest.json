{
  "manifest_version": 3,
  "name": "Khazana PDF Downloader",
  "version": "1.5.6",
  "permissions": [
    "webRequest",
    "storage",
    "downloads",
    "scripting",
    "tabs",
    "webNavigation",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.xylem.live/*",
        "*://*.pw.live/*",
        "*://samsung-pre-prod.pw.live/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}