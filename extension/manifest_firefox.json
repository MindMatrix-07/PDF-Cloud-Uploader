{
  "manifest_version": 3,
  "name": "Khazana PDF Downloader",
  "version": "1.7.0",
  "description": "Auto-detects and uploads PDFs from Khazana/PW to your MEGA cloud.",
  "browser_specific_settings": {
    "gecko": {
      "id": "khazana-snatcher@extension",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": [
    "webRequest",
    "storage",
    "downloads",
    "scripting",
    "tabs",
    "webNavigation",
    "notifications",
    "cookies"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.xylem.live/*",
        "*://*.pw.live/*",
        "*://*.khazana.in/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
